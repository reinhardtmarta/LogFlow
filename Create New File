    "            return self.handle_fallback()\n",
    "\n",
    "        # 2. VALIDATE & TRANSFORM: Build HTML Cards\n",
    "        html_output = \"<h3 style='color: #2c3e50;'>📍 Nearby Availability Found:</h3>\"\n",
