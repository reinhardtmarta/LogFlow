    "                \"Expiry_Date\": expiry_val,\n",
    "                \"Price\": s_price.value,\n",
    "                \"Last_Updated\": datetime.datetime.now(),\n",
    "                \"Discount\": applied_discount\n",
    "            }\n",
    "\n",
    "            # 3. Sync with Shared DataFrame\n",
    "            msg = agent.update_inventory(new_data)\n",
