    "        try:\n",
    "            expiry_val = s_exp.value\n",
    "            if not expiry_val:\n",
    "                print(\"❌ Please select an expiry date.\")\n",
    "                return\n",
    "\n",
    "            # 2. Validation & Smart Logic\n",
    "            days_to_expiry = (expiry_val - datetime.date.today()).days\n",
