    "import sqlite3\n",
    "import pandas as pd\n",
    "import datetime\n",
    "import random\n",
    "\n",
    "# ==========================================\n",
    "# 1. DATASET GENERATION (Real-World Style)\n",
    "# ==========================================\n",
    "def initialize_real_data():\n",
    "    conn = sqlite3.connect('logiflow_real.db')\n",
    "    cursor = conn.cursor()\n",
    "\n",
    "    # Create Tables\n",
    "    cursor.execute(\"DROP TABLE IF EXISTS inventory\")\n",
    "    cursor.execute(\"DROP TABLE IF EXISTS products\")\n",
    "\n",
    "    cursor.execute('''CREATE TABLE products (\n",
    "                        product_id INTEGER PRIMARY KEY,\n",
    "                        name TEXT,\n",
    "                        category TEXT)''')\n",
    "\n",
    "    cursor.execute('''CREATE TABLE inventory (\n",
    "                        item_id INTEGER PRIMARY KEY,\n",
    "                        product_id INTEGER,\n",
    "                        quantity INTEGER,\n",
    "                        site TEXT,\n",
    "                        sector TEXT,\n",
    "                        shelf TEXT,\n",
    "                        expiry_date DATE,\n",
    "                        condition TEXT,\n",
    "                        FOREIGN KEY(product_id) REFERENCES products(product_id))''')\n",
    "\n",
    "    # Mocking Public Retail Data (FMCG Style)\n",
    "    products = [\n",
    "        (1, 'Organic Orange Juice', 'Beverages'),\n",
    "        (2, 'Almond Milk', 'Dairy'),\n",
    "        (3, 'Greek Yogurt', 'Dairy'),\n",
    "        (4, 'Whole Grain Bread', 'Bakery'),\n",
    "        (5, 'Avocado (Organic)', 'Produce'),\n",
    "        (6, 'Salted Butter', 'Dairy'),\n",
    "        (7, 'Oat Milk', 'Beverages'),\n",
    "        (8, 'Dark Chocolate', 'Snacks')\n",
    "    ]\n",
    "    \n",
    "    sites = ['Site-SP', 'Site-RJ', 'Site-MG']\n",
    "    sectors = ['Sector-A', 'Sector-B', 'Sector-C']\n",
    "    conditions = ['new', 'new', 'used', 'new'] # Mix of conditions\n",
    "\n",
    "    cursor.executemany(\"INSERT INTO products VALUES (?,?,?)\", products)\n",
    "\n",
    "    # Generate 50 rows of realistic inventory\n",
    "    inventory_rows = []\n",
    "    for i in range(1, 51):\n",
    "        p_id = random.randint(1, 8)\n",
    "        qty = random.randint(5, 200)\n",
    "        site = random.choice(sites)\n",
    "        sec = random.choice(sectors)\n",
    "        shelf = f\"Shelf-{random.randint(1, 20)}\"\n",
    "        # Random expiry dates: some in past, some in future\n",
    "        days_diff = random.randint(-10, 60)\n",
    "        expiry = (datetime.date.today() + datetime.timedelta(days=days_diff)).isoformat()\n",
    "        cond = random.choice(conditions)\n",
    "        inventory_rows.append((i, p_id, qty, site, sec, shelf, expiry, cond))\n",
    "\n",
    "    cursor.executemany(\"INSERT INTO inventory VALUES (?,?,?,?,?,?,?,?)\", inventory_rows)\n",
    "    conn.commit()\n",
    "    conn.close()\n",
    "    print(\"✅ Database 'logiflow_real.db' initialized with real-world retail data.\")\n",
    "\n",
    "# ==========================================\n",
    "# 2. THE INTELLIGENT ENGINE (Gemma Workflow Simulation)\n",
    "# ==========================================\n",
    "\n",
    "class LogiFlowIntelligence:\n",
    "    def __init__(self, db_path):\n",
    "        self.db_path = db_path\n",
    "        self.schema = \"\"\"\n",
    "        Table 'products': product_id (INT), name (TEXT), category (TEXT)\n",
    "        Table 'inventory': item_id (INT), product_id (INT), quantity (INT), \n",
    "                          site (TEXT), sector (TEXT), shelf (TEXT), \n",
    "                          expiry_date (DATE), condition (TEXT)\n",
    "        \"\"\"\n",
    "\n",
    "    def _mock_gemma_text_to_sql(self, user_query):\n",
    "        \"\"\"\n",
    "        In production, this replaces a call to Gemma: \n",
    "        response = gemma.generate(prompt=f\"{self.schema} Query: {user_query}\")\n",
    "        \"\"\"\n",
    "        print(f\"[Gemma-SQL-Agent] Analyzing NLU for: '{user_query}'\")\n",
    "        \n",
    "        # Logic simulating Gemma's reasoning\n",
    "        if \"juice\" in user_query.lower() and \"sector-c\" in user_query.lower():\n",
    "            return \"SELECT p.name, i.quantity, i.site, i.sector FROM inventory i JOIN products p ON i.product_id = p.product_id WHERE p.name LIKE '%Juice%' AND i.sector = 'Sector-C';\"\n",
    "        \n",
    "        elif \"expiring\" in user_query.lower() or \"expiry\" in user_query.lower():\n",
    "            return \"SELECT p.name, i.expiry_date, i.quantity FROM inventory i JOIN products p ON i.product_id = p.product_id WHERE i.expiry_date <= date('now', '+10 days');\"\n",
    "        \n",
    "        elif \"total\" in user_query.lower() and \"stock\" in user_query.lower():\n",
    "            return \"SELECT SUM(quantity) FROM inventory;\"\n",
    "            \n",
    "        else:\n",
    "            return \"SELECT * FROM inventory LIMIT 5;\" # Fallback\n",
    "\n",
    "    def _mock_gemma_synthesis(self, query, dataframe):\n",
    "        \"\"\"\n",
    "        In production, this replaces:\n",
    "        response = gemma.generate(prompt=f\"Translate this data to human: {dataframe}\")\n",
    "        \"\"\"\n",
    "        print(f\"[Gemma-Synthesis-Agent] Synthesizing data into Natural Language...\")\n",
    "        if dataframe.empty:\n",
    "            return \"I searched the database, but I couldn't find any items matching your request.\"\n",
    "        \n",
    "        if \"SUM\" in query:\n",
    "            total = dataframe.iloc[0, 0]\n",
    "            return f\"📊 The current total stock across all sites is {total} units.\"\n",
    "        \n",
    "        if \"expiry\" in query.lower():\n",
    "            items = dataframe.to_dict('records')\n",
    "            msg = \"⚠️ **EXPIRATION ALERT**: The following items are expiring soon:\\n\"\n",
    "            for item in items:\n",
    "                msg += f\"- {item['name']}: expires on {item['expiry_date']} ({item['quantity']} units)\\n\"\n",
    "            return msg\n",
    "\n",
    "        return f\"✅ Here is what I found:\\n{dataframe.to_string(index=False)}\"\n",
    "\n",
    "    def process_request(self, user_query):\n",
    "        print(f\"\\n{'='*50}\")\n",
    "        print(f\"USER REQUEST: {user_query}\")\n",
    "        print(f\"{'='*50}\")\n",
    "\n",
    "        # 1. Text-to-SQL (Gemma Step 1)\n",
    "        sql_query = self._mock_gemma_text_to_sql(user_query)\n",
    "        print(f\"GENERATED SQL: {sql_query}\")\n",
    "\n",
    "        # 2. Execution (Database Step)\n",
    "        try:\n",
    "            conn = sqlite3.connect(self.db_path)\n",
    "            df = pd.read_sql_query(sql_query, conn)\n",
    "            conn.close()\n",
    "\n",
    "            # 3. Synthesis (Gemma Step 2)\n",
    "            final_answer = self._mock_gemma_synthesis(sql_query, df)\n",
    "            return final_answer\n",
    "\n",
    "        except Exception as e:\n",
    "            return f\"❌ Error executing query: {str(e)}\"\n",
    "\n",
    "# ==========================================\n",
    "# 3. RUN THE TEST SUITE\n",
    "# ==========================================\n",
    "\n",
    "initialize_real_data()\n",
    "engine = LogiFlowIntelligence('logiflow_real.db')\n",
    "\n",
    "# Test 1: Specific Entity + Constraint (NLU Test)\n",
    "print(engine.process_request(\"Show me all organic juices in Sector-C\"))\n",
    "\n",
    "# Test 2: Proactive Expiry (Alert Test)\n",
    "print(engine.process_request(\"Which items are expiring in the next 10 days?\"))\n",
    "\n",
    "# Test 3: Aggregation (Reporting Test)\n",
    "print(engine.process_request(\"What is the total stock count?\"))"
   ]
