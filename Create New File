    "            <h3 style=\"color: #c0392b;\">⚠️ No local stock verified today.</h3>\n",
    "            <a href=\"https://www.google.com/shopping\" target=\"_blank\" style=\"color: #3498db;\">Redirecting to Global Google Shopping...</a>\n",
    "            </div>\"\"\"\n",
    "\n",
    "    def update_inventory(self, new_entry: dict):\n",
    "        \"\"\"SELLER SIDE: Upsert logic to update or append data.\"\"\"\n",
    "        global public_inventory\n",
    "        \n",
    "        # Check if (Product + Store) already exists for UPSERT logic\n",
    "        mask = (public_inventory['Product'] == new_entry['Product']) & \\\n",
    "               (public_inventory['Store_Name'] == new_entry['Store_Name'])\n",
    "        \n",
    "        new_row = pd.DataFrame([new_entry])\n",
    "        \n",
    "        if not self.df[mask].empty:\n",
    "            # UPDATE existing\n",
    "            self.df.loc[mask, ['Stock_Qty', 'Price', 'Expiry_Date', 'Last_Updated', 'Discount']] = \\\n",
    "                [new_entry['Stock_Qty'], new_entry['Price'], new_entry['Expiry_Date'], \n",
    "                 new_entry['Last_Updated'], new_entry['Discount']]\n",
    "            return \"✅ Stock Updated Successfully!\"\n",
    "        else:\n",
    "            # APPEND new\n",
    "            self.df = pd.concat([self.df, new_row], ignore_index=True)\n",
    "            return \"✅ New Product Registered & Broadcasted!\"\n",
    "\n",
    "# Initialize Agent with the shared reference\n",
    "agent = LogiflowAgent(public_inventory)\n",
