    "        self.df = df  # This is a reference to the global DataFrame\n",
    "\n",
    "    def search_and_format(self, query):\n",
    "        \"\"\"USER SIDE: Search and display results.\"\"\"\n",
    "        results = self.df[self.df['Product'].str.contains(query, case=False, na=False)]\n",
    "        \n",
    "        if results.empty or results['Stock_Qty'].sum() == 0:\n",
    "            return self.handle_fallback()\n",
    "\n",
    "        html_output = \"<h3 style='color: #2c3e50;'>📍 Local Availability:</h3><div style='display: flex; flex-wrap: wrap; gap: 15px;'>\"\n",
    "        today = datetime.date.today()\n",
    "\n",
    "        for _, row in results.iterrows():\n",
    "            # Check for Zero Waste status\n",
    "            days_to_exp = (row['Expiry_Date'] - today).days\n",
    "            is_zero_waste = row['Discount'] != \"0%\" or days_to_exp < 3\n",
    "            \n",
    "            discount_tag = \"\"\n",
    "            if is_zero_waste:\n",
    "                discount_tag = f'<div style=\"background-color: #e74c3c; color: white; padding: 4px; border-radius: 4px; font-size: 10px; font-weight: bold; margin-top: 5px;\">🔥 LOGIFLOW ZERO WASTE DEAL</div>'\n",
    "\n",
    "            html_output += f\"\"\"\n",
    "            <div style=\"border: 1px solid #ddd; border-radius: 8px; padding: 15px; width: 220px; background-color: white; box-shadow: 2px 2px 10px rgba(0,0,0,0.1); font-family: sans-serif;\">\n",
    "                <div style=\"font-size: 11px; color: #27ae60; font-weight: bold;\">✅ {row['Store_Name']} (Verified)</div>\n",
    "                <div style=\"font-size: 15px; font-weight: bold; color: #2c3e50; margin: 5px 0;\">{row['Product']}</div>\n",
    "                <div style=\"font-size: 13px; color: #7f8c8d;\">📍 {row['Distance_km']} km away</div>\n",
